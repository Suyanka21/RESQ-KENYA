rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User profile photos
    match /users/{userId}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Provider documents (verification)
    match /providers/{providerId}/documents/{fileName} {
      allow read: if request.auth.uid == providerId;
      allow write: if request.auth.uid == providerId
                   && request.resource.size < 10 * 1024 * 1024;  // Max 10MB
    }
    
    // Service request photos (incident/completion proof)
    match /requests/{requestId}/photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
