{
  "expo": {
    "name": "ResQ",
    "slug": "resq-kenya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "resq",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.geometryltd.resq",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ResQ needs your location to connect you with nearby service providers.",
        "NSLocationAlwaysUsageDescription": "ResQ needs your location to track service providers on the way to help you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.geometryltd.resq",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ResQ needs your location to connect you with nearby service providers."
        }
      ]
    ]
  }
}